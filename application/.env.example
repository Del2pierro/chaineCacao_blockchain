# ─────────────────────────────────────────────────────────────────────────────
# .env — Configuration de l'application cliente
# Copier ce fichier en .env et adapter selon votre environnement
# ─────────────────────────────────────────────────────────────────────────────

# Réseau Fabric
CHANNEL_NAME=cacao-cafe-channel
CHAINCODE_NAME=trace-cacao

# Identité de l'utilisateur
MSP_ID=Org1MSP

# Chemins des certificats (relatifs à la racine du projet)
CRYPTO_BASE=../organizations/peerOrganizations/org1.example.com

KEY_DIR_PATH=${CRYPTO_BASE}/users/User1@org1.example.com/msp/keystore
CERT_PATH=${CRYPTO_BASE}/users/User1@org1.example.com/msp/signcerts/User1@org1.example.com-cert.pem

# TLS du peer
TLS_CERT_PATH=${CRYPTO_BASE}/peers/peer0.org1.example.com/tls/ca.crt

# Adresse du peer gRPC
PEER_ENDPOINT=localhost:7051
PEER_HOST_ALIAS=peer0.org1.example.com

# Port du serveur API Express
API_PORT=3000
